{
  "version": 1,
  "application": {
    "name": "oficina-cadastro",
    "environment": "Production",
    "containerPort": 8080
  },
  "aws": {
    "clusterNameParameter": "/oficina/infra/cluster/name",
    "ecrRepositoryParameter": "/oficina/infra/ecr/cadastro",
    "regionFromWorkflow": true
  },
  "kubernetes": {
    "namespace": "oficina",
    "deploymentName": "oficina-cadastro",
    "serviceName": "oficina-cadastro",
    "runtimeServiceAccount": "cadastro-runtime",
    "migrationServiceAccount": "cadastro-migrator",
    "replicas": 1
  },
  "secrets": {
    "runtimeDatabase": "/oficina/cadastro/runtime-db",
    "migrationDatabase": "/oficina/cadastro/migration-db"
  },
  "health": {
    "path": "/health",
    "readinessPath": "/ready",
    "initialDelaySeconds": 10,
    "periodSeconds": 10,
    "timeoutSeconds": 3,
    "failureThreshold": 6
  },
  "deployment": {
    "progressDeadlineSeconds": 600,
    "terminationGracePeriodSeconds": 30
  }
}
